# Enable/disable Google Calendar sync for Event saves.
GOOGLE_CALENDAR_SYNC_ENABLED=1

# Optional override. If omitted, main.py will auto-detect from site/content/calendar.md.
# GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# IANA timezone used when start/end times are present.
GOOGLE_CALENDAR_TIMEZONE=America/Chicago

# Path to your Google service account JSON credentials file.
GOOGLE_SERVICE_ACCOUNT_FILE=google-service-account.json
